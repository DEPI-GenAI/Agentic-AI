# API Keys - Never commit real keys!
# Used by optional remote validation / tool-calling parts.
GROQ_API_KEY=your_groq_api_key_here

# Local HuggingFace token (only needed if you run gated/local models).
HUGGINGFACE_TOKEN=your_huggingface_token_here

# ---- Model names (can override defaults) ----
DECISION_ENGINE_MODEL_NAME=microsoft/Phi-3.5-mini-instruct
ANALYTICS_CODE_MODEL_NAME=microsoft/Phi-3.5-mini-instruct
GROQ_VALIDATOR_MODEL=llama-3.3-70b-versatile

# ---- API behavior ----
REQUEST_TIMEOUT_SECONDS=90.0

# ---- Optional analytics dataset wiring ----
# If you wire `memory/TelecomTickets.csv` in your server code, set the path here.
# ANALYTICS_CSV_PATH=/absolute/path/to/TelecomTickets.csv
